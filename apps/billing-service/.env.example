PORT=4000

# asaas (padrao) | pagarme
BILLING_PROVIDER=asaas

# --- Asaas (https://api-sandbox.asaas.com/v3 em sandbox) ---
ASAAS_API_KEY=$aact_hmlg_your_sandbox_key
ASAAS_WEBHOOK_TOKEN=token_que_voce_configura_no_painel_asaas
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_USER_AGENT=baseMedicalSaas-billing/1.0

# --- Pagar.me (alternativa / backup) ---
PAGARME_API_KEY=sk_test_your-pagarme-api-key
PAGARME_WEBHOOK_SECRET=your-pagarme-webhook-hmac-secret

# --- Supabase (service role) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

FRONTEND_URL=http://localhost:3000
